# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/peerlearn
# For production with authentication:
# MONGO_URI=mongodb://username:password@localhost:27017/peerlearn?authSource=admin

# Redis Cache
REDIS_URL=redis://localhost:6379

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRE=7d

# ==========================================
# File Upload (Cloudinary)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# Email Configuration (SendGrid/Nodemailer)
# ==========================================
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@peerlearn.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key

# ==========================================
# Stripe Payments
# ==========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ==========================================
# AI Services
# ==========================================
OPENAI_API_KEY=sk-your_openai_api_key
GOOGLE_AI_API_KEY=your_google_ai_key
DEEPGRAM_API_KEY=your_deepgram_api_key

# ==========================================
# Client URL (for CORS)
# ==========================================
CLIENT_URL=http://localhost:3000

# ==========================================
# Security
# ==========================================
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Feature Flags (Optional)
# ==========================================
ENABLE_AI_TRANSCRIPTION=false
ENABLE_SCREEN_SHARING=true
ENABLE_RECORDING=true

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ==========================================
# MongoDB Docker (for docker-compose)
# ==========================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=secure_password_here
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=secure_password_here
