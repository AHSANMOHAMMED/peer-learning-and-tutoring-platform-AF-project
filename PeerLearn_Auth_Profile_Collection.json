  "item": [
    {
      "name": "1. Registration & Login",
      "description": "User registration, login, and logout flows",
      "item": [
        {
          "name": "1.1 POST - Register (Student)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "",
                  "pm.test('[Auth] POST Register Student - Status 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('[Auth] POST Register - Response has success property', function () {",
                  "  pm.expect(responseJson).to.have.property('success', true);",
                  "});",
                  "",
                  "pm.test('[Auth] POST Register - JWT token returned', function () {",
                  "  pm.expect(responseJson.data).to.have.property('token');",
                  "  pm.expect(responseJson.data.token).to.be.a('string');",
                  "  pm.environment.set('jwtToken', responseJson.data.token);",
                  "});",
                  "",
                  "pm.test('[Auth] POST Register - User object created', function () {",
                  "  pm.expect(responseJson.data.user).to.have.property('_id');",
                  "  pm.expect(responseJson.data.user).to.have.property('email');",
                  "  pm.expect(responseJson.data.user).to.have.property('role');",
                  "  pm.environment.set('userId', responseJson.data.user._id);",
                  "  pm.environment.set('userEmail', responseJson.data.user.email);",
                  "  pm.environment.set('userPassword', 'SecurePass123!');",
                  "});",
                  "",
                  "pm.test('[Auth] POST Register - Role is student', function () {",
                  "  pm.expect(responseJson.data.user.role).to.equal('student');",
                  "});",
                  "",
                  "pm.test('[Auth] POST Register - Email verified or pending', function () {",
                  "  pm.expect(responseJson.data.user).to.have.property('emailVerified');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ahmedkhan2024\",\n  \"email\": \"ahmed.khan@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"student\",\n  \"profile\": {\n    \"firstName\": \"Ahmed\",\n    \"lastName\": \"Khan\",\n    \"grade\": 10,\n    \"phone\": \"+94771234567\",\n    \"school\": \"Royal College\",\n    \"bio\": \"Grade 10 student interested in Mathematics and Physics\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
