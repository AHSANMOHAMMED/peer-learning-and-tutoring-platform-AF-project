                  "});",
                  "pm.test('Response has answers array', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('answers');",
                  "  pm.expect(jsonData.answers).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/questions/{{questionId}}/answers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "questions", "{{questionId}}", "answers"]
            }
