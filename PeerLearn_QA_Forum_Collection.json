{
  "info": {
    "_postman_id": "qa-forum-collection",
    "name": "PeerLearn - Q&A Forum",
    "description": "Complete Postman Collection for Q&A Forum APIs including Questions, Answers, Comments, Voting, and Leaderboards. Tests all CRUD operations and voting mechanisms.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Questions CRUD",
      "item": [
        {
          "name": "1.1 POST - Create Question",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const jwt = pm.environment.get('jwtToken');",
                  "if (!jwt) {",
                  "  throw new Error('Missing jwtToken. Select environment and run Auth login/register first.');",
                  "}",
                  "pm.request.headers.upsert({",
                  "  key: 'Authorization',",
                  "  value: 'Bearer ' + jwt",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function() {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Question has required fields', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('_id');",
                  "  pm.expect(jsonData).to.have.property('title');",
                  "  pm.expect(jsonData).to.have.property('body');",
                  "  pm.expect(jsonData).to.have.property('author');",
                  "  pm.expect(jsonData).to.have.property('tags');",
                  "  pm.expect(jsonData).to.have.property('createdAt');",
                  "});",
                  "pm.test('Extract question ID', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.environment.set('questionId', jsonData._id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"How to solve quadratic equations?\",\n  \"content\": \"I'm struggling with the quadratic formula. Can someone explain step by step how to apply it? I need help understanding when to use which method.\",\n  \"subject\": \"Mathematics\",\n  \"tags\": [\"algebra\", \"equations\", \"help\"],\n  \"grade\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/questions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "questions"]
            }
          }
        },
        {
          "name": "1.2 GET - Get All Questions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has questions array', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('questions');",
                  "  pm.expect(jsonData.questions).to.be.an('array');",
                  "});",
                  "pm.test('Questions have required fields', function() {",
                  "  const jsonData = pm.response.json();",
                  "  if(jsonData.questions && jsonData.questions.length > 0) {",
                  "    pm.expect(jsonData.questions[0]).to.have.property('_id');",
                  "    pm.expect(jsonData.questions[0]).to.have.property('title');",
                  "    pm.expect(jsonData.questions[0]).to.have.property('author');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/questions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "questions"]
            }
          }
        },
        {
          "name": "1.3 GET - Get Question by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const jwt = pm.environment.get('jwtToken');",
                  "if (jwt) {",
                  "  pm.request.headers.add({",
                  "    key: 'Authorization',",
                  "    value: 'Bearer ' + jwt",
                  "  });",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Question has all details', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.question).to.have.property('_id');",
                  "  pm.expect(jsonData.question).to.have.property('title');",
                  "  pm.expect(jsonData.question).to.have.property('body');",
                  "  pm.expect(jsonData.question).to.have.property('views');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "questions", "{{questionId}}"]
            }
          }
        },
        {
          "name": "1.4 PUT - Update Question",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const jwt = pm.environment.get('jwtToken');",
                  "if (jwt) {",
                  "  pm.request.headers.add({",
                  "    key: 'Authorization',",
                  "    value: 'Bearer ' + jwt",
                  "  });",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Question updated successfully', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.title).to.include('Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated: How to solve quadratic equations?\",\n  \"content\": \"I'm struggling with the quadratic formula. Can someone explain step by step? UPDATED\",\n  \"tags\": [\"algebra\", \"equations\", \"help\", \"urgent\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "questions", "{{questionId}}"]
            }
          }
        },
        {
          "name": "1.5 DELETE - Delete Question",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const jwt = pm.environment.get('jwtToken');",
                  "if (jwt) {",
                  "  pm.request.headers.add({",
                  "    key: 'Authorization',",
                  "    value: 'Bearer ' + jwt",
                  "  });",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Question deleted successfully', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "questions", "{{questionId}}"]
            }
          }
        }
