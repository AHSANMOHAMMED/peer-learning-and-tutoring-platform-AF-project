          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"The quadratic formula is x = (-b ± √(b²-4ac)) / 2a. First, identify your a, b, and c coefficients from the equation ax²+bx+c=0. Then substitute into the formula. For example, if you have x²+3x+2=0, then a=1, b=3, c=2.\",\n  \"codeExample\": \"x = (-3 ± √(9-8)) / 2 = (-3 ± 1) / 2\\nSolution: x = -1 or x = -2\",\n  \"isMarkedAsCorrect\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/questions/{{questionId}}/answers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "questions", "{{questionId}}", "answers"]
            }
          }
        },
